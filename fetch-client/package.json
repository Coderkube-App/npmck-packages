{
  "name": "@coderkube/fetch-client",
  "version": "1.0.0",
  "description": "Cross-platform API client for Next.js, React, React Native, and Vanilla.js with interceptors, retries, and TypeScript support.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.mjs",
      "require": "./dist/react.js"
    },
    "./react-native": {
      "types": "./dist/react-native.d.ts",
      "import": "./dist/react-native.mjs",
      "require": "./dist/react-native.js"
    },
    "./vanilla": {
      "types": "./dist/vanilla.d.ts",
      "import": "./dist/vanilla.mjs",
      "require": "./dist/vanilla.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/react.tsx src/react-native.ts src/vanilla.ts --format cjs,esm --dts --minify --clean",
    "test": "vitest run",
    "dev": "tsup src/index.ts --format cjs,esm --watch --dts",
    "lint": "tsc"
  },
  "keywords": [
    "api",
    "client",
    "http",
    "fetch",
    "axios",
    "react",
    "nextjs",
    "react-native",
    "vanilla",
    "interceptor",
    "request"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.16",
    "@types/react": "^18.2.0",
    "react": "^18.2.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^1.2.2"
  },
  "peerDependencies": {
    "react": ">=16.8.0"
  }
}
